UPLOAD_ENABLED=false

# Đường dẫn file nhạc nền (bắt buộc khi render video)
# macOS/Linux: BACKGROUND_AUDIO_PATH=/Users/yourname/music/background01.mp3
# Windows:     BACKGROUND_AUDIO_PATH=E:\20.tainguyen\background01.mp3
# Nếu để trống, mặc định tìm tại assets/background01.mp3 trong thư mục repo
BACKGROUND_AUDIO_PATH=

# Video chi tiết 1 tin hot nhất bằng Gemini
# Nếu không set GEMINI_API_KEY, script tự fallback sang heuristic viralScore.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
HOT_STORY_CANDIDATE_COUNT=12
HOT_STORY_DURATION_TARGET=75
# Tuỳ chọn: ép pipeline dùng một URL bài báo cụ thể để test/debug.
# HOT_STORY_FORCE_URL=https://vnexpress.net/...
HOT_STORY_FORCE_URL=

# Giọng đọc hook bằng VieNeu-TTS. Mặc định tắt để workflow cũ không đổi.
# Cài SDK trong Python env dùng để chạy: pip install vieneu
HOOK_TTS_ENABLED=false
HOOK_TTS_PROVIDER=vieneu
HOOK_TTS_PYTHON=
HOOK_TTS_START_OFFSET=0.45
HOOK_TTS_MAX_SECONDS=6.8
HOOK_TTS_VOLUME=1.0
BACKGROUND_VOLUME=0.42
BACKGROUND_VOLUME_WITH_TTS=0.25
VIENEU_MODE=standard
VIENEU_EMOTION=natural
VIENEU_VOICE_ID=
VIENEU_API_BASE=
VIENEU_MODEL_NAME=pnnbao-ump/VieNeu-TTS-v2

# Facebook Page Reels
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# YouTube Data API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
# PUBLIC_TO_EVERYONE, MUTUAL_FOLLOW_FRIENDS, FOLLOWER_OF_CREATOR, or SELF_ONLY
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE
